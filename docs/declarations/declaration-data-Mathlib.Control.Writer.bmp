 is used to derive instances for both `[EmptyCollection ω] [Append ω]` and `[Monoid ω]`.\n"},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Control/Writer.lean#L50-L50","name":"WriterT.runThe","docLink":"./Mathlib/Control/Writer.html#WriterT.runThe","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Control/Writer.lean#L49-L49","name":"WriterT.run","docLink":"./Mathlib/Control/Writer.html#WriterT.run","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Control/Writer.lean#L48-L48","name":"WriterT.mk","docLink":"./Mathlib/Control/Writer.html#WriterT.mk","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Control/Writer.lean#L41-L44","name":"instMonadWriterStateT","docLink":"./Mathlib/Control/Writer.html#instMonadWriterStateT","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Control/Writer.lean#L36-L39","name":"instMonadWriterReaderT","docLink":"./Mathlib/Control/Writer.html#instMonadWriterReaderT","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Control/Writer.lean#L27-L30","name":"MonadWriter","docLink":"./Mathlib/Control/Writer.html#MonadWriter","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Control/Writer.lean#L25-L25","name":"Writer","docLink":"./Mathlib/Control/Writer.html#Writer","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Control/Writer.lean#L21-L22","name":"WriterT","docLink":"./Mathlib/Control/Writer.html#WriterT","doc":""}]}