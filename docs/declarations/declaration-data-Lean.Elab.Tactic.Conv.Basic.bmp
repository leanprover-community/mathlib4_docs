com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Lean/Elab/Tactic/Conv/Basic.lean#L79-L81","name":"Lean.Elab.Tactic.Conv.evalWhnf","docLink":"./Lean/Elab/Tactic/Conv/Basic.html#Lean.Elab.Tactic.Conv.evalWhnf","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Lean/Elab/Tactic/Conv/Basic.lean#L74-L77","name":"Lean.Elab.Tactic.Conv.changeLhs","docLink":"./Lean/Elab/Tactic/Conv/Basic.html#Lean.Elab.Tactic.Conv.changeLhs","doc":"Replace `lhs` with the definitionally equal `lhs'`. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Lean/Elab/Tactic/Conv/Basic.lean#L67-L71","name":"Lean.Elab.Tactic.Conv.updateLhs","docLink":"./Lean/Elab/Tactic/Conv/Basic.html#Lean.Elab.Tactic.Conv.updateLhs","doc":"`⊢ lhs = rhs` ~~> `⊢ lhs' = rhs` using `h : lhs = lhs'`. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Lean/Elab/Tactic/Conv/Basic.lean#L63-L64","name":"Lean.Elab.Tactic.Conv.getRhs","docLink":"./Lean/Elab/Tactic/Conv/Basic.html#Lean.Elab.Tactic.Conv.getRhs","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Lean/Elab/Tactic/Conv/Basic.lean#L60-L61","name":"Lean.Elab.Tactic.Conv.getLhs","docLink":"./Lean/Elab/Tactic/Conv/Basic.html#Lean.Elab.Tactic.Conv.getLhs","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Lean/Elab/Tactic/Conv/Basic.lean#L57-L58","name":"Lean.Elab.Tactic.Conv.getLhsRhs","docLink":"./Lean/Elab/Tactic/Conv/Basic.html#Lean.Elab.Tactic.Conv.getLhsRhs","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Lean/Elab/Tactic/Conv/Basic.lean#L52-L55","name":"Lean.Elab.Tactic.Conv.getLhsRhsCore","docLink":"./Lean/Elab/Tactic/Conv/Basic.html#Lean.Elab.Tactic.Conv.getLhsRhsCore","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Lean/Elab/Tactic/Conv/Basic.lean#L33-L50","name":"Lean.Elab.Tactic.Conv.convert","docLink":"./Lean/Elab/Tactic/Conv/Basic.html#Lean.Elab.Tactic.Conv.convert","doc":"Given `lhs`, runs the `conv` tactic with the goal `⊢ lhs = ?rhs`.\n`conv` should produce no remaining goals that are not solvable with refl.\nReturns a pair of instantiated expressions `(?rhs, ?p)` where `?p : lhs = ?rhs`. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Lean/Elab/Tactic/Conv/Basic.lean#L24-L28","name":"Lean.Elab.Tactic.Conv.markAsConvGoal","docLink":"./Lean/Elab/Tactic/Conv/Basic.html#Lean.Elab.Tactic.Conv.markAsConvGoal","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Lean/Elab/Tactic/Conv/Basic.lean#L17-L22","name":"Lean.Elab.Tactic.Conv.mkConvGoalFor","docLink":"./Lean/Elab/Tactic/Conv/Basic.html#Lean.Elab.Tactic.Conv.mkConvGoalFor","doc":"Given `lhs`, returns a pair of metavariables `(?rhs, ?newGoal)`\nwhere `?newGoal : lhs = ?rhs`."}]}