ver/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1330-L1331","name":"List.toArray","docLink":"./Init/Prelude.html#List.toArray","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1325-L1327","name":"List.redLength","docLink":"./Init/Prelude.html#List.redLength","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1320-L1322","name":"List.toArrayAux","docLink":"./Init/Prelude.html#List.toArrayAux","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1310-L1316","name":"Array.appendCore.loop","docLink":"./Init/Prelude.html#Array.appendCore.loop","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1309-L1317","name":"Array.appendCore","docLink":"./Init/Prelude.html#Array.appendCore","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1305-L1306","name":"Array.set!","docLink":"./Init/Prelude.html#Array.set!","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1301-L1302","name":"Array.setD","docLink":"./Init/Prelude.html#Array.setD","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1297-L1299","name":"Array.set","docLink":"./Init/Prelude.html#Array.set","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1292-L1294","name":"Array.push","docLink":"./Init/Prelude.html#Array.push","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1288-L1289","name":"instGetElemArrayNatLtInstLTNatSize","docLink":"./Init/Prelude.html#instGetElemArrayNatLtInstLTNatSize","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1285-L1286","name":"Array.get!","docLink":"./Init/Prelude.html#Array.get!","doc":"\"Comfortable\" version of `fget`. It performs a bound check at runtime. "},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1280-L1281","name":"Array.getD","docLink":"./Init/Prelude.html#Array.getD","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1277-L1278","name":"Array.get","docLink":"./Init/Prelude.html#Array.get","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1273-L1274","name":"Array.size","docLink":"./Init/Prelude.html#Array.size","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1269-L1270","name":"Array.empty","docLink":"./Init/Prelude.html#Array.empty","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1265-L1267","name":"Array.mkEmpty","docLink":"./Init/Prelude.html#Array.mkEmpty","doc":"The parameter `c` is the initial capacity "},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1257-L1258","name":"Array","docLink":"./Init/Prelude.html#Array","doc":"The Compiler has special support for arrays.\nThey are implemented using dynamic arrays: https://en.wikipedia.org/wiki/Dynamic_array\n"},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1248-L1249","name":"GetElem","docLink":"./Init/Prelude.html#GetElem","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1242-L1243","name":"panic","docLink":"./Init/Prelude.html#panic","doc":"This is workaround for `panic` occurring in monadic code. See issue #695.\nThe `panicCore` definition cannot be specialized since it is an extern.\nWhen `panic` occurs in monadic code, the `Inhabited α` parameter depends on a `[inst : Monad m]` instance.\nThe `inst` parameter will not be eliminated during specialization if it occurs inside of a binder (to avoid work duplication), and\nwill prevent the the actual monad from being \"copied\" to the code being specialized. When we reimplement the specializer, we\nmay consider copying `inst` if it also occurs outside binders or if it is an instance.\n"},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1231-L1231","name":"panicCore","docLink":"./Init/Prelude.html#panicCore","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1227-L1228","name":"unsafeCast","docLink":"./Init/Prelude.html#unsafeCast","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1221-L1225","name":"String.toSubstring","docLink":"./Init/Prelude.html#String.toSubstring","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1218-L1219","name":"String.endPos","docLink":"./Init/Prelude.html#String.endPos","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1215-L1216","name":"instDecidableLtPosInstLTPos","docLink":"./Init/Prelude.html#instDecidableLtPosInstLTPos","doc":""},{"sourceLink":"https://github.com/leanprover/lean4/blob/6a767a66a13c588cce3829bf1de00a1830883843/src/Init/Prelude.lean#L1212-L1213",