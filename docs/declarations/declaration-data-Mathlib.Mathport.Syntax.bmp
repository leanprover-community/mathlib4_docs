/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Mathport/Syntax.lean#L61-L61","name":"Lean.Parser.Command.omit","docLink":"./Mathlib/Mathport/Syntax.html#Lean.Parser.Command.omit","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Mathport/Syntax.lean#L60-L60","name":"Lean.Parser.Command.include","docLink":"./Mathlib/Mathport/Syntax.html#Lean.Parser.Command.include","doc":""}]}