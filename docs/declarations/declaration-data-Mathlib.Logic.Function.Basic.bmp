hlib/Logic/Function/Basic.lean#L233-L234","name":"Function.LeftInverse.RightInverse","docLink":"./Mathlib/Logic/Function/Basic.html#Function.LeftInverse.RightInverse","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L229-L231","name":"Function.RightInverse.comp","docLink":"./Mathlib/Logic/Function/Basic.html#Function.RightInverse.comp","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L225-L227","name":"Function.LeftInverse.comp","docLink":"./Mathlib/Logic/Function/Basic.html#Function.LeftInverse.comp","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L222-L223","name":"Function.RightInverse_iff_comp","docLink":"./Mathlib/Logic/Function/Basic.html#Function.RightInverse_iff_comp","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L219-L220","name":"Function.RightInverse.comp_eq_id","docLink":"./Mathlib/Logic/Function/Basic.html#Function.RightInverse.comp_eq_id","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L216-L217","name":"Function.LeftInverse_iff_comp","docLink":"./Mathlib/Logic/Function/Basic.html#Function.LeftInverse_iff_comp","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L213-L214","name":"Function.LeftInverse.comp_eq_id","docLink":"./Mathlib/Logic/Function/Basic.html#Function.LeftInverse.comp_eq_id","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L209-L211","name":"Function.injective_of_partial_inv_right","docLink":"./Mathlib/Logic/Function/Basic.html#Function.injective_of_partial_inv_right","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L205-L206","name":"Function.injective_of_partial_inv","docLink":"./Mathlib/Logic/Function/Basic.html#Function.injective_of_partial_inv","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L202-L203","name":"Function.is_partial_inv_left","docLink":"./Mathlib/Logic/Function/Basic.html#Function.is_partial_inv_left","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L199-L200","name":"Function.is_partial_inv","docLink":"./Mathlib/Logic/Function/Basic.html#Function.is_partial_inv","doc":"`g` is a partial inverse to `f` (an injective but not necessarily\nsurjective function) if `g y = some x` implies `f x = y`, and `g y = none`\nimplies that `y` is not in the range of `f`. "},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L190-L194","name":"Function.cantor_injective","docLink":"./Mathlib/Logic/Function/Basic.html#Function.cantor_injective","doc":"Cantor's diagonal argument implies that there are no injective functions from `Set α` to `α`. "},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L185-L187","name":"Function.cantor_surjective","docLink":"./Mathlib/Logic/Function/Basic.html#Function.cantor_surjective","doc":"Cantor's diagonal argument implies that there are no surjective functions from `α`\nto `Set α`. "},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L179-L181","name":"Function.bijective.of_comp_iff'","docLink":"./Mathlib/Logic/Function/Basic.html#Function.bijective.of_comp_iff'","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L175-L177","name":"Function.bijective.of_comp_iff","docLink":"./Mathlib/Logic/Function/Basic.html#Function.bijective.of_comp_iff","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L171-L173","name":"Function.bijective.exists_unique","docLink":"./Mathlib/Logic/Function/Basic.html#Function.bijective.exists_unique","doc":"Shorthand for using projection notation with `function.bijective_iff_exists_unique`. "},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L163-L169","name":"Function.bijective_iff_exists_unique","docLink":"./Mathlib/Logic/Function/Basic.html#Function.bijective_iff_exists_unique","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L159-L161","name":"Function.surjective.exists₃","docLink":"./Mathlib/Logic/Function/Basic.html#Function.surjective.exists₃","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L155-L157","name":"Function.surjective.exists₂","docLink":"./Mathlib/Logic/Function/Basic.html#Function.surjective.exists₂","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Logic/Function/Basic.lean#L149-L153","name":"Function.surjective.exists","docLink":"./Mathlib/Logic/Function/Basic.html#Function.surjective.exists","d