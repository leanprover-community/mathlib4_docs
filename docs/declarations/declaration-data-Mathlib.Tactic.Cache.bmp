{"name":"Mathlib.Tactic.Cache","instances":[{"typeNames":["Tactic.Cache"],"name":"Tactic.instNonemptyCache","className":"Nonempty"},{"typeNames":["Tactic.DeclCache"],"name":"Tactic.instNonemptyDeclCache","className":"Nonempty"}],"imports":["Init","Lean","Mathlib.Logic.Nonempty"],"declarations":[{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Tactic/Cache.lean#L123-L127","name":"Tactic.DeclCache.get","docLink":"./Mathlib/Tactic/Cache.html#Tactic.DeclCache.get","doc":"Access the cache.\nCalling this function for the first time\nwill initialize the cache with the function\nprovided in the constructor.\n"},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Tactic/Cache.lean#L108-L115","name":"Tactic.DeclCache.mk","docLink":"./Mathlib/Tactic/Cache.html#Tactic.DeclCache.mk","doc":"Creates a `DeclCache`.\nThe cached structure `α` is initialized with `empty`,\nand then `addDecl` is called for every constant in the environment.\nCalls to `addDecl` for imported constants are cached.\n"},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Tactic/Cache.lean#L99-L100","name":"Tactic.instNonemptyDeclCache","docLink":"./Mathlib/Tactic/Cache.html#Tactic.instNonemptyDeclCache","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Tactic/Cache.lean#L96-L97","name":"Tactic.DeclCache","docLink":"./Mathlib/Tactic/Cache.html#Tactic.DeclCache","doc":"Cached fold over the environment's declarations,\nwhere a given function is applied to `α` for every constant.\n"},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Tactic/Cache.lean#L66-L90","name":"Tactic.Cache.get","docLink":"./Mathlib/Tactic/Cache.html#Tactic.Cache.get","doc":"Access the cache.\nCalling this function for the first time\nwill initialize the cache with the function\nprovided in the constructor.\n"},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Tactic/Cache.lean#L57-L58","name":"Tactic.Cache.mk","docLink":"./Mathlib/Tactic/Cache.html#Tactic.Cache.mk","doc":"Creates a cache with an initialization function. "},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Tactic/Cache.lean#L53-L54","name":"Tactic.instNonemptyCache","docLink":"./Mathlib/Tactic/Cache.html#Tactic.instNonemptyCache","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Tactic/Cache.lean#L49-L51","name":"Tactic.Cache","docLink":"./Mathlib/Tactic/Cache.html#Tactic.Cache","doc":"Once-per-file cache. "}]}