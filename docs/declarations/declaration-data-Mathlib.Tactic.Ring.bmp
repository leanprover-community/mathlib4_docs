{"name":"Mathlib.Tactic.Ring","instances":[{"typeNames":["Tactic.Ring.HornerExpr"],"name":"Tactic.Ring.instInhabitedHornerExpr","className":"Inhabited"},{"typeNames":["Tactic.Ring.HornerExpr","Lean.Expr"],"name":"Tactic.Ring.HornerExpr.instCoeHornerExprExpr","className":"Coe"}],"imports":["Init","Lean.Elab.Tactic.Basic","Mathlib.Algebra.Ring.Basic","Mathlib.Tactic.NormNum"],"declarations":[{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Tactic/Ring.lean#L411-L411","name":"Tactic.Ring.tacticRing","docLink":"./Mathlib/Tactic/Ring.html#Tactic.Ring.tacticRing","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Tactic/Ring.lean#L382-L409","name":"Tactic.Ring.eval","docLink":"./Mathlib/Tactic/Ring.html#Tactic.Ring.eval","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Tactic/Ring.lean#L378-L380","name":"Tactic.Ring.subst_into_pow","docLink":"./Mathlib/Tactic/Ring.html#Tactic.Ring.subst_into_pow","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Tactic/Ring.lean#L374-L376","name":"Tactic.Ring.subst_into_mul","docLink":"./Mathlib/Tactic/Ring.html#Tactic.Ring.subst_into_mul","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Tactic/Ring.lean#L370-L372","name":"Tactic.Ring.subst_into_add","docLink":"./Mathlib/Tactic/Ring.html#Tactic.Ring.subst_into_add","doc":""},{"sourceLink":"https://github.com/leanprover-community/mathlib4/blob/876d9cc42ccbfea023752e40e6edb7279d9c6b5a/Mathlib/Tactic/Ring.lean#L364-L368","name":"Tactic.Ring.evalAtom","docLink":"./Mathlib/Tactic/Ring.html#Tactic.Ring.evalAtom","doc":"Evaluate `a` where `a` is an atom. "},{"sourceLink":"https://github.com/leanprover-community/mathlib4/